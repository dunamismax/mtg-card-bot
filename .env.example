# MTG Card Bot Configuration
# Copy this file to .env and fill in your values

# Required: Your Discord bot token
MTG_DISCORD_TOKEN=your_discord_bot_token_here

# Optional: Command prefix (default: !)
MTG_COMMAND_PREFIX=!

# Optional: Logging configuration
MTG_LOG_LEVEL=INFO
MTG_JSON_LOGGING=false

# Optional: PostgreSQL connection string
# When set, the bot initializes a connection pool and persists lookup history.
# When unset, the bot runs in stateless mode (no persistent storage).
# Format: postgresql://user:password@host:5432/dbname
# MTG_DATABASE_URL=postgresql://mtg:secret@localhost:5432/mtg_card_bot